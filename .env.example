XERO_AUTH_CLIENT_ID=your-client-id
XERO_AUTH_CLIENT_SECRET=your-client-secret
# Required: set the exact scopes allowed by your Xero app
XERO_AUTH_SCOPES="openid profile email offline_access accounting.transactions accounting.contacts accounting.settings.read accounting.reports.read"
# Optional defaults
# XERO_TENANT=your-default-tenant-id
# XERO_AUTH_OPEN_COMMAND=open
